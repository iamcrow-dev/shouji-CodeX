{
  "name": "codex-host-app",
  "version": "1.1.1",
  "private": true,
  "description": "win\u684c\u9762CodeX",
  "author": "qwe",
  "type": "module",
  "main": "src/main.js",
  "scripts": {
    "start": "electron .",
    "check": "node --check src/main.js && node --check src/config-store.js && node --check src/service/token.js && node --check src/service/port.js && node --check src/service/codex-path.js && node --check src/service/codex-bridge.js && node --check src/service/host-service.js && node --check src/close-confirm-preload.cjs && node --check src/renderer/app.js && node --check src/renderer/close-confirm.js",
    "dist:mac": "electron-builder --mac dmg zip",
    "dist:win": "electron-builder --win zip"
  },
  "dependencies": {
    "express": "^5.1.0",
    "ws": "^8.18.3"
  },
  "devDependencies": {
    "electron": "^37.2.0",
    "electron-builder": "^25.1.8"
  },
  "build": {
    "appId": "com.qwe.codexhost",
    "productName": "win\u684c\u9762CodeX",
    "directories": {
      "output": "dist"
    },
    "files": [
      "src/**/*",
      "assets/**/*",
      "package.json"
    ],
    "artifactName": "${productName}-${version}-${arch}.${ext}",
    "asar": true,
    "mac": {
      "category": "public.app-category.developer-tools",
      "target": [
        "dmg",
        "zip"
      ],
      "icon": "assets/codex-icon.icns",
      "extendInfo": {
        "CFBundleShortVersionString": "1.1.1",
        "CFBundleVersion": "1.1.1"
      }
    },
    "win": {
      "target": [
        "zip"
      ],
      "icon": "assets/codex-icon.ico",
      "signAndEditExecutable": false,
      "artifactName": "codex-host-app-${version}-${arch}.${ext}"
    },
    "dmg": {}
  }
}
